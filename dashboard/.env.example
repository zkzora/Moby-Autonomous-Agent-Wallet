# ── Moby dashboard — environment (Phase 1: testnet) ──────────────────────
# Copy to `.env.local` and fill in after publishing the Move package.

# The published `moby_policy` package id (0x…). Until this is set, the UI runs
# in "package not deployed" mode and disables on-chain transactions.
VITE_MOBY_PACKAGE_ID=

# Optional: override the delegated agent address shown by default in the form.
# Defaults to a deterministic mock address if unset.
VITE_MOBY_AGENT_ADDRESS=
